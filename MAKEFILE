# Yuuki Chess Engine Makefile
# Supports cross-compilation via CROSS_COMPILE variable
# Usage: make (defaults to native) or make CROSS_COMPILE=aarch64-linux-gnu-

CXX = $(CROSS_COMPILE)g++
CXXFLAGS = -std=c++17 -O3 -flto -pthread -Wall -Wextra
TARGET = yuuki
SOURCES = $(wildcard src/*.cpp)
OBJECTS = $(SOURCES:.cpp=.o)

all: $(TARGET)

$(TARGET): $(OBJECTS)
	$(CXX) $(CXXFLAGS) -o $@ $^

%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -f $(OBJECTS) $(TARGET)
	rm -f src/*.o

.PHONY: all clean

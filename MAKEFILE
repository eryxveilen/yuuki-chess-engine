# Yuuki Chess Engine Makefile
# For Linux/macOS/Windows (MinGW)

CXX = g++
CXXFLAGS = -std=c++17 -O3 -flto -march=native -Wall -Wextra -pthread
TARGET = yuuki
SOURCES = $(wildcard src/*.cpp)
OBJECTS = $(SOURCES:.cpp=.o)

all: $(TARGET)

$(TARGET): $(OBJECTS)
	$(CXX) $(CXXFLAGS) -o $@ $^

%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -f $(OBJECTS) $(TARGET)
	rm -f src/*.o

.PHONY: all clean
